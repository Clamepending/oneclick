NODE_ENV=development
APP_BASE_URL=http://localhost:3000
APP_NAME=OneClickOpenClaw

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_COOKIE_DOMAIN=
BOT_AUTH_LOGIN_BASE_URL=
ADMIN_EMAILS=

DATABASE_URL=postgresql://user:pass@localhost:5432/oneclick
REDIS_URL=redis://localhost:6379

# Legacy SSH host pools are optional and should stay empty in ECS-first setups.
HOST_POOL_JSON=
HOST_MAX_CONTAINERS=50
HOST_PLACEMENT_STRATEGY=least_loaded
RUNTIME_BASE_DOMAIN=oneclickagent.net
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
BOT_DASHBOARD_BASE_DOMAIN=
ENABLE_WILDCARD_SUBDOMAINS=false
CADDY_EMAIL=
DEPLOY_PROVIDER=ecs
DEPLOY_PROVIDER_LIGHTSAIL=ecs
AWS_REGION=us-east-1
DEPLOY_QUEUE_LAMBDA_FUNCTION_NAME=oneclick-sqs-deploy-consumer
AWS_ACCOUNT_ID=
ECS_CLUSTER=
ECS_SUBNET_IDS=
ECS_SECURITY_GROUP_IDS=
ECS_EXECUTION_ROLE_ARN=
ECS_TASK_ROLE_ARN=
ECS_SERVICE_PREFIX=oneclick-agent
# Optional isolated service prefix used only by testing canary flavor `simple_agent_ottoauth_ecs_canary`
ECS_CANARY_SERVICE_PREFIX=oneclick-agent-canary
ECS_TASK_CPU=512
ECS_TASK_MEMORY=2048
ECS_TASK_CPU_FREE=512
ECS_TASK_MEMORY_FREE=2048
ECS_TASK_CPU_PAID=1024
ECS_TASK_MEMORY_PAID=3072
PLAN_STORAGE_GB_FREE=1
PLAN_STORAGE_GB_PAID=10
ECS_ASSIGN_PUBLIC_IP=true
ECS_LOG_GROUP=
ECS_LOG_STREAM_PREFIX=oneclick
ECS_READY_URL_TEMPLATE=
ECS_VPC_ID=
# Optional shared HTTPS ALB routing for ECS runtimes (recommended)
ECS_RUNTIME_ALB_ENABLED=false
ECS_RUNTIME_ALB_HTTPS_LISTENER_ARN=
ECS_RUNTIME_ALB_BASE_DOMAIN=
ECS_RUNTIME_ALB_HEALTH_PATH=/__openclaw/control-ui-config.json
ECS_RUNTIME_ALB_HEALTH_MATCHER=200-499
ECS_RUNTIME_ALB_RULE_PRIORITY_MIN=10000
ECS_RUNTIME_ALB_RULE_PRIORITY_MAX=49999
OPENCLAW_SSH_TIMEOUT_MS=120000
OPENCLAW_HOST_PORT_BASE=20000
OPENCLAW_HOST_PORT_SPAN=10000
DEPLOY_SSH_PRIVATE_KEY=
DEPLOY_SSH_KNOWN_HOSTS=

OPENCLAW_IMAGE=ghcr.io/phioranex/openclaw-docker@sha256:REPLACE_WITH_PINNED_DIGEST
OPENCLAW_REQUIRE_PINNED_IMAGE=true
OPENCLAW_CONTAINER_PORT=18789
OPENCLAW_START_COMMAND=gateway --allow-unconfigured
OPENCLAW_ALLOW_INSECURE_CONTROL_UI=true
OPENCLAW_NODE_OPTIONS=--max-old-space-size=1536
OPENCLAW_CONFIG_MOUNT_BASE=/var/lib/oneclick/openclaw
OPENCLAW_WORKSPACE_SUFFIX=workspace
OPENCLAW_HEALTH_PATH=/health
OPENCLAW_STARTUP_TIMEOUT_MS=120000
ECS_SMOKE_TELEGRAM_TOKEN=

SIMPLE_AGENT_IMAGE=oneclick/simpleagent:main
SIMPLE_AGENT_BUILD_ON_HOST=true
SIMPLE_AGENT_BUILD_REPO=https://github.com/Clamepending/simpleagent.git#main
SIMPLE_AGENT_CONTAINER_PORT=18789
SIMPLE_AGENT_START_COMMAND=
SIMPLE_AGENT_MODEL=gpt-4o-mini
SIMPLE_AGENT_LLM_URL=
SIMPLE_AGENT_MICROSERVICES_FRONTEND_IMAGE=
SIMPLE_AGENT_MICROSERVICES_GATEWAY_IMAGE=
SIMPLE_AGENT_MICROSERVICES_EXECUTION_IMAGE=
SIMPLE_AGENT_MICROSERVICES_POST_IMAGE=
SIMPLE_AGENT_MICROSERVICES_REDIS_IMAGE=redis:7-alpine
SIMPLE_AGENT_MICROSERVICES_POSTGRES_IMAGE=postgres:16-alpine
SIMPLE_AGENT_MICROSERVICES_POSTGRES_USER=simpleagent
SIMPLE_AGENT_MICROSERVICES_POSTGRES_PASSWORD=simpleagent
SIMPLE_AGENT_MICROSERVICES_POSTGRES_DB=simpleagent
SIMPLE_AGENT_MICROSERVICES_FRONTEND_PORT=18789
SIMPLE_AGENT_MICROSERVICES_FRONTEND_START_COMMAND=
SIMPLE_AGENT_MICROSERVICES_TASK_CPU=
SIMPLE_AGENT_MICROSERVICES_TASK_MEMORY=
SIMPLE_AGENT_MICROSERVICES_HEALTH_PATH=/health
SIMPLE_AGENT_MICROSERVICES_TELEGRAM_API_BASE=https://api.telegram.org
SIMPLE_AGENT_MICROSERVICES_TELEGRAM_MOCK_ENABLED=false
SIMPLE_AGENT_MICROSERVICES_TELEGRAM_MOCK_IMAGE=
SIMPLE_AGENT_MICROSERVICES_MCP_IMAGE=
SIMPLE_AGENT_MICROSERVICES_MCP_TOOL_SERVICE_URL=http://127.0.0.1:8004
SIMPLE_AGENT_MICROSERVICES_MCP_AUTO_OFF_IDLE_S=300
SIMPLE_AGENT_MICROSERVICES_MCP_LOOP_INTERVAL_S=1
SIMPLE_AGENT_MICROSERVICES_SYSTEM_PROMPT=You are a concise, helpful assistant.
OTTOAGENT_IMAGE=oneclick/ottoagent:main
OTTOAGENT_BUILD_ON_HOST=true
OTTOAGENT_BUILD_REPO=https://github.com/Clamepending/simpleagent.git#main
OTTOAGENT_CONTAINER_PORT=18789
OTTOAGENT_START_COMMAND=
OTTOAGENT_MODEL=gpt-4o-mini
OTTOAGENT_LLM_URL=
OTTOAGENT_MCP_IMAGE=oneclick/ottoagent-mcp:main
OTTOAGENT_MCP_BUILD_ON_HOST=true
OTTOAGENT_MCP_BUILD_REPO=
OTTOAGENT_MCP_PORT=8787
OTTOAGENT_MCP_PATH=/mcp
OTTOAGENT_MCP_START_COMMAND=
OTTOAGENT_MCP_BASE_URL=https://ottoauth.vercel.app
OTTOAGENT_MCP_TOKEN=
VIDEOMEMORY_IMAGE=oneclick/videomemory:main
VIDEOMEMORY_BUILD_ON_HOST=true
VIDEOMEMORY_BUILD_REPO=https://github.com/Clamepending/videomemory.git#main
VIDEOMEMORY_CONTAINER_PORT=5050
VIDEOMEMORY_START_COMMAND=

DEPLOY_RATE_LIMIT_PER_MIN=5
DEPLOYMENTS_PAUSED=false
DEPLOY_MAX_IN_PROGRESS_GLOBAL=
DEPLOY_MAX_READY_GLOBAL=
DEPLOY_AUTO_STOP_READY_AFTER_MINUTES=
DEPLOY_COST_GUARD_SWEEP_LIMIT=25
DEPLOY_COST_GUARD_DRY_RUN=false
DEPLOY_POLL_INTERVAL_MS=3000
NEXT_PUBLIC_DEPLOY_POLL_INTERVAL_MS=10000
PG_POOL_MAX=1
PG_IDLE_TIMEOUT_MS=10000
PG_CONNECTION_TIMEOUT_MS=5000

EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=

LOG_LEVEL=info
SENTRY_DSN=
